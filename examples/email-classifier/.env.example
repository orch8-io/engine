# ─── DeepSeek (classification via built-in llm_call) ────────────────────────
# Get from: https://platform.deepseek.com/api_keys
# Free tier gives $5 credit — enough for thousands of classifications.
# Used by the engine's built-in llm_call handler (OpenAI-compatible endpoint).
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Slack (notification via Activepieces sidecar) ──────────────────────────
# 1. Create app: https://api.slack.com/apps → Create New App → From Scratch
# 2. OAuth & Permissions → Bot Token Scopes → add: chat:write
# 3. Install to Workspace → copy the xoxb-... token below
# 4. Invite bot to channel: /invite @YourBot
SLACK_ACCESS_TOKEN=xoxb-000000000000-000000000000-xxxxxxxxxxxxxxxxxxxxxxxx

# Right-click the target channel → View channel details → copy ID at the bottom.
SLACK_CHANNEL_ID=C0123456789

# ─── Orch8 engine ───────────────────────────────────────────────────────────
# Base URL of your running orch8 engine instance.
# The worker and webhook adapter both connect here.
ORCH8_URL=http://localhost:8080

# ─── Webhook adapter ────────────────────────────────────────────────────────
# Port the webhook adapter listens on. Ngrok should point here.
WEBHOOK_PORT=3333

# ─── Resend (inbound email) ────────────────────────────────────────────────
# Optional: webhook signing secret for verifying Resend payloads.
# Get from: https://resend.com/webhooks (shown after creating webhook)
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
