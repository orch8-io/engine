# orch8-engine — example environment configuration.
# Copy to `.env` (or set these in your deploy platform). Every value here can
# also be set in the config TOML; env vars take precedence.

# --- Core ---------------------------------------------------------------
ORCH8_HTTP_ADDR=0.0.0.0:8080
ORCH8_API_KEY=                       # required unless started with --insecure
ORCH8_LOG_LEVEL=info
ORCH8_LOG_JSON=true

# --- Storage ------------------------------------------------------------
ORCH8_STORAGE_BACKEND=postgres       # postgres | sqlite
ORCH8_DATABASE_URL=postgres://user:pass@localhost:5432/orch8
ORCH8_RUN_MIGRATIONS=true

# --- Encryption at rest -------------------------------------------------
# 32-byte key as 64 hex chars. Encrypts instance context, credentials, AND
# artifact bytes (when the EncryptingStorage wrapper is enabled).
ORCH8_ENCRYPTION_KEY=
# ORCH8_OLD_ENCRYPTION_KEY=          # set during key rotation only

# --- Artifacts (durable binary blobs produced/consumed by steps) --------
# backend: none (default, artifacts disabled) | local | s3
ORCH8_ARTIFACT_BACKEND=none
#
# local backend — durable ONLY on a persistent volume. On ephemeral container
# filesystems (Cloud Run, k8s without a PVC) artifacts are lost on restart.
# The path MUST be absolute. Prefer s3 for cloud deployments.
ORCH8_ARTIFACT_PATH=/var/lib/orch8/artifacts
#
# s3-compatible backend (AWS S3 / Cloudflare R2 / MinIO). Also configure a
# bucket lifecycle (TTL) policy as defense-in-depth against orphaned blobs.
ORCH8_ARTIFACT_S3_BUCKET=
ORCH8_ARTIFACT_S3_REGION=
ORCH8_ARTIFACT_S3_ENDPOINT=          # empty → AWS default; set for R2/MinIO
ORCH8_ARTIFACT_S3_ACCESS_KEY_ID=
ORCH8_ARTIFACT_S3_SECRET_ACCESS_KEY=
ORCH8_ARTIFACT_S3_ALLOW_HTTP=false   # true only for local MinIO over HTTP
#
# Automatic retention: delete an instance's artifacts this many seconds after it
# reaches a terminal state. 0 (default) = never auto-delete (keep until removed
# out-of-band, e.g. an S3 lifecycle policy). Example: 2592000 = 30 days.
ORCH8_ARTIFACT_RETENTION_SECS=0

# NOTE: the artifact backend must be configured BEFORE deploying any sequence
# that uses `response_as: "artifact"` or `body_artifact` — otherwise those
# steps fail with a permanent "artifact storage is not configured" error.

# --- Telemetry (OpenTelemetry trace export) ------------------------------
# OTLP collector endpoint (gRPC), e.g. http://localhost:4317 — Langfuse,
# Datadog Agent, Grafana Alloy, otel-collector. Empty/unset = export disabled
# (zero overhead). Exports `orch8.step` spans (one per step execution; LLM
# steps carry the `gen_ai.client.inference` event). Standard OTEL_SERVICE_NAME
# and OTEL_RESOURCE_ATTRIBUTES env vars are honored.
ORCH8_OTLP_ENDPOINT=
ORCH8_OTLP_PROTOCOL=grpc             # grpc (only supported value)

# --- Outbound webhooks ---------------------------------------------------
ORCH8_WEBHOOK_URLS=                  # comma-separated delivery URLs
# Optional shared secret. When set, each delivery is signed:
#   X-Orch8-Timestamp + X-Orch8-Signature: sha256=HMAC-SHA256(secret,"{ts}.{body}")
ORCH8_WEBHOOK_SECRET=
