#!/usr/bin/env bash
# Pre-push hook: mirrors the CI "Check & Lint" job so lint failures are caught
# before they reach GitHub Actions.
#
# To enable:  git config core.hooksPath .githooks
# To skip once: git push --no-verify

set -euo pipefail

# Run from the repo root regardless of where the push was invoked from.
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[pre-push] cargo fmt --check"
cargo fmt --check

echo "[pre-push] cargo clippy --workspace -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "[pre-push] cargo check --workspace"
cargo check --workspace

echo "[pre-push] OK"
