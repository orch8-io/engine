#!/usr/bin/env bash
# Pre-push hook: mirrors the CI "Check & Lint" job so lint failures are caught
# before they reach GitHub Actions.
#
# To enable:  git config core.hooksPath .githooks
# To skip once: git push --no-verify

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

export SQLX_OFFLINE=true

echo "[pre-push] cargo fmt --check"
cargo fmt --check

echo "[pre-push] cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "[pre-push] cargo check --workspace"
cargo check --workspace

echo "[pre-push] cargo deny check"
if command -v cargo-deny &>/dev/null; then
    cargo deny check
else
    echo "  (skipped — install with: cargo install cargo-deny)"
fi

echo "[pre-push] OK"
