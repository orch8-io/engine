{
  "name": "@orch8/loadgen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Continuous workflow load generator for the orch8 engine — drives the dashboard with realistic traffic and doubles as a stress tool.",
  "bin": {
    "orch8-loadgen": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "light": "tsx src/index.ts --preset=light",
    "steady": "tsx src/index.ts --preset=steady",
    "stress": "tsx src/index.ts --preset=stress",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test --test-timeout=60000 tests/integration.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
