{
  "id": "00000000-0000-0000-0000-000000000002",
  "tenant_id": "mobile",
  "namespace": "default",
  "name": "payment-verification",
  "version": 1,
  "deprecated": false,
  "blocks": [
    {
      "type": "step",
      "id": "init_payment",
      "handler": "init_payment",
      "params": {},
      "cancellable": true
    },
    {
      "type": "step",
      "id": "validate_amount",
      "handler": "validate_amount",
      "params": { "min": 1, "max": 10000, "currency": "USD" },
      "cancellable": true
    },
    {
      "type": "step",
      "id": "fraud_check",
      "handler": "fraud_check",
      "params": { "provider": "internal" },
      "cancellable": true
    },
    {
      "type": "step",
      "id": "risk_assessment",
      "handler": "risk_assessment",
      "params": { "threshold": 0.7 },
      "cancellable": true
    },
    {
      "type": "step",
      "id": "compliance_check",
      "handler": "compliance_check",
      "params": { "regulations": ["AML", "KYC"] },
      "cancellable": true
    },
    {
      "type": "step",
      "id": "payment_approval",
      "handler": "request_approval",
      "params": { "reviewer": "finance_team", "reason": "payment_authorization" },
      "cancellable": true,
      "wait_for_input": {
        "prompt": "Payment requires authorization. Please review the transaction details and approve or reject.",
        "timeout": 86400000,
        "choices": [
          { "label": "Approve Payment", "value": "approved" },
          { "label": "Reject Payment", "value": "rejected" }
        ],
        "store_as": "payment_decision"
      }
    },
    {
      "type": "router",
      "id": "payment_decision_gate",
      "routes": [
        {
          "condition": "context.data.payment_decision == 'rejected'",
          "blocks": [
            {
              "type": "step",
              "id": "show_rejection_banner",
              "handler": "show_banner",
              "params": {
                "title": "Payment Declined",
                "message": "Your payment was not approved. The amount will be refunded to your account within 3-5 business days.",
                "style": "error"
              },
              "cancellable": true
            }
          ]
        }
      ],
      "default": [
        {
          "type": "step",
          "id": "process_payment",
          "handler": "process_payment",
          "params": { "gateway": "stripe" },
          "cancellable": true
        },
        {
          "type": "step",
          "id": "show_success_banner",
          "handler": "show_banner",
          "params": {
            "title": "Payment Successful",
            "message": "Your payment has been processed successfully. A receipt has been sent to your email.",
            "style": "success"
          },
          "cancellable": true
        },
        {
          "type": "step",
          "id": "send_receipt",
          "handler": "send_receipt",
          "params": {},
          "cancellable": true
        }
      ]
    }
  ],
  "created_at": "2026-05-17T00:00:00Z"
}
